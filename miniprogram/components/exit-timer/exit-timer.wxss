/* movable-area must be position:fixed and full viewport for the
   movable-view to be draggable across the whole screen. */
.exit-timer-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 950;
  pointer-events: none;
  background: transparent;
}

.exit-timer-mover {
  /* Sized to fit pill content so movable-view's left edge aligns with the
     pill itself — keeps the flush-right default from leaving an empty gap. */
  width: 320rpx;
  height: 80rpx;
  pointer-events: auto;
}

.exit-timer-mover.is-dev {
  /* DEV chip widens the pill; mover follows so drag bounds match. */
  width: 460rpx;
}

.exit-timer-pill {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  height: 100%;
  padding: 0 18rpx;
  background: rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(249, 188, 96, 0.6);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
  white-space: nowrap;
}

.exit-timer-icon {
  font-size: 28rpx;
  line-height: 1;
}

.exit-timer-body {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1.1;
}

.exit-timer-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

.exit-timer-time {
  font-size: 28rpx;
  font-weight: bold;
  color: #f9bc60;
  font-family: monospace;
  letter-spacing: 2rpx;
}

/* Inline chip — same slot for +88 and the dev-skip indicator. */
.exit-timer-chip {
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 20rpx;
  letter-spacing: 1rpx;
}

.exit-timer-reward {
  background: #f9bc60;
  color: #2a1a00;
}

.exit-timer-dev {
  background: rgba(249, 188, 96, 0.85);
  color: #2a1a00;
}
