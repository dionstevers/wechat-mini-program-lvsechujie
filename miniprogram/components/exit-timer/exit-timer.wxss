.exit-timer-pill {
  position: fixed;
  top: calc(20rpx + env(safe-area-inset-top));
  right: 20rpx;
  z-index: 950;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  background: rgba(0, 0, 0, 0.55);
  border: 1rpx solid rgba(249, 188, 96, 0.6);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  pointer-events: auto;
}

.exit-timer-icon {
  font-size: 28rpx;
  line-height: 1;
}

.exit-timer-body {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  line-height: 1.1;
}

.exit-timer-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

.exit-timer-time {
  font-size: 28rpx;
  font-weight: bold;
  color: #f9bc60;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.exit-timer-dev {
  margin-left: 6rpx;
  padding: 2rpx 10rpx;
  background: rgba(249, 188, 96, 0.85);
  color: #2a1a00;
  font-size: 18rpx;
  font-weight: bold;
  border-radius: 6rpx;
  letter-spacing: 1rpx;
}
