.survey-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, #00022a 0%, #009797 100%);
  padding-bottom: 40rpx;
  overflow-x: hidden;
}

.survey-header {
  padding: 30rpx 30rpx 20rpx;
  background: rgba(0, 0, 0, 0.2);
}

.progress-bar-wrap {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  background: #f9bc60;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-label {
  text-align: right;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.block-intro {
  padding: 20rpx 30rpx 0;
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  font-style: italic;
}

.questions-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 30rpx;
}

.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  width: 100%;
}

.intro-card {
  background: rgba(255, 255, 255, 0.12);
}

.intro-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.7;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 28rpx;
  display: block;
}

/* Single select */
.option-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.option-row:last-child {
  border-bottom: none;
}

.option-label {
  font-size: 28rpx;
  color: #444;
  margin-left: 16rpx;
}

/* Slider */
.slider-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.slider-min-label,
.slider-max-label {
  font-size: 22rpx;
  color: #888;
}

.slider-placeholder {
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
}

/* Matrix */
.matrix-wrap {
  overflow-x: auto;
}

.matrix-header-row,
.matrix-data-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.matrix-row-label {
  flex: 2;
  font-size: 26rpx;
  color: #555;
  padding-right: 12rpx;
}

.matrix-col-label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #888;
  padding: 8rpx 0;
}

.matrix-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
}

.matrix-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  background: #fff;
}

.matrix-radio-selected {
  background: #419f8c;
  border-color: #419f8c;
}

.matrix-data-row:not(:last-child) {
  border-bottom: 1rpx solid #f0f0f0;
}

/* Dropdown / Picker */
.picker-display {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #aaa;
}

.picker-selected {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 22rpx;
  color: #999;
}

/* Open text */
.open-text-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* Navigation buttons */
.nav-buttons {
  padding: 20rpx 30rpx 40rpx;
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.btn-back {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
}

.btn-next,
.btn-submit {
  flex: 2;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.btn-disabled {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.4);
}
