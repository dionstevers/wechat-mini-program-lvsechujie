.survey-container {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, #00022a 0%, #0a4f6e 55%, #009797 100%);
  padding-bottom: 40rpx;
  overflow-x: hidden;
}

/* Decor blobs (mirrors landing/consent/registration) */
.landing-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
  z-index: 0;
}
.decor-a {
  width: 360rpx; height: 360rpx;
  top: -120rpx; left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.decor-b {
  width: 420rpx; height: 420rpx;
  top: 200rpx; right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.decor-c {
  width: 320rpx; height: 320rpx;
  bottom: 220rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.survey-header {
  position: relative;
  z-index: 1;
  padding: 30rpx 30rpx 20rpx;
  background: rgba(0, 0, 0, 0.2);
}

.survey-header-card {
  position: relative;
  z-index: 1;
  margin: 24rpx 30rpx 0;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
}

.survey-header-text {
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  line-height: 1.55;
  letter-spacing: 1rpx;
}

.survey-header-accent {
  width: 96rpx;
  height: 6rpx;
  background: #f9bc60;
  border-radius: 4rpx;
  margin-top: 20rpx;
}

.survey-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.completion-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.completion-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.completion-bar-track {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.completion-bar-fill {
  height: 100%;
  background: #f9bc60;
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.progress-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  white-space: nowrap;
}

.block-intro {
  padding: 20rpx 30rpx 0;
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  font-style: italic;
}

.questions-scroll {
  position: relative;
  z-index: 1;
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 36rpx 30rpx 20rpx;
}

.question-card {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  width: 100%;
}

/* scroll-view clips children at its own edge — keep badge inside the card top. */
.question-card .coin-badge {
  top: 12rpx;
  right: 12rpx;
}

/* .coin-badge style now lives in app.wxss (shared with button badges). */

.intro-card {
  background: rgba(255, 255, 255, 0.12);
}

.question-card.statement-card {
  padding: 36rpx 36rpx 24rpx;
}

.statement-text {
  margin-bottom: 0;
  padding-right: 0 !important;
}

.intro-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.7;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 28rpx;
  padding-right: 100rpx;
  display: block;
}

/* Single select */
.option-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.option-row:last-child {
  border-bottom: none;
}

.option-label {
  font-size: 28rpx;
  color: #444;
  margin-left: 16rpx;
}

/* Slider */
.slider-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.slider-min-label,
.slider-max-label {
  font-size: 22rpx;
  color: #888;
}

.slider-placeholder {
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
}

/* Matrix */
.matrix-wrap {
  overflow-x: auto;
}

.matrix-header-row,
.matrix-data-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.matrix-row-label {
  flex: 2;
  font-size: 26rpx;
  color: #555;
  padding-right: 12rpx;
}

.matrix-col-label {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #888;
  padding: 8rpx 0;
}

.matrix-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
}

.matrix-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  background: #fff;
}

.matrix-radio-selected {
  background: #419f8c;
  border-color: #419f8c;
}

.matrix-data-row:not(:last-child) {
  border-bottom: 1rpx solid #f0f0f0;
}

/* Dropdown / Picker */
.picker-display {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  height: 60rpx;
  box-sizing: border-box;
  padding: 0 24rpx 24rpx 24rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.picker-placeholder {
  font-size: 26rpx;
  line-height: 1;
  color: #aaa;
}

.picker-selected {
  font-size: 26rpx;
  line-height: 1;
  color: #333;
}

.picker-arrow {
  font-size: 20rpx;
  line-height: 1;
  margin-top: 20rpx;
  color: #999;
}

/* Open text */
.open-text-input {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* Navigation buttons */
.nav-buttons {
  position: relative;
  z-index: 1;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.btn-back {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 60rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
}

.btn-submit-wrap {
  flex: 2;
}

.btn-next,
.btn-submit {
  flex: 2;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #ffd27a 0%, #f9bc60 60%, #e5a23a 100%);
  color: #2a1a00;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(249, 188, 96, 0.45), inset 0 -2rpx 0 rgba(0, 0, 0, 0.08);
}
.btn-next::after,
.btn-submit::after,
.btn-back::after { border: none; }

.btn-disabled {
  background: rgba(255, 255, 255, 0.2) !important;
  color: rgba(255, 255, 255, 0.4) !important;
  box-shadow: none !important;
}
