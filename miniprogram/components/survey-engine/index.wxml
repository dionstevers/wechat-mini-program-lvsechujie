<!-- survey-engine component
     Renders one block at a time. Fires 'survey-complete' event with all responses when done. -->

<view class="survey-container">

  <view class="landing-decor decor-a"></view>
  <view class="landing-decor decor-b"></view>
  <view class="landing-decor decor-c"></view>

  <!-- Progress bar -->
  <view class="survey-header">
    <view class="survey-header-row">
      <view class="completion-wrap">
        <text class="completion-label">问卷进度</text>
        <view class="completion-bar-track">
          <view class="completion-bar-fill" style="width: {{completionPct}}%"></view>
        </view>
      </view>
      <view class="progress-label">
        <text>{{currentBlockIndex + 1}} / {{totalBlocks}}</text>
      </view>
    </view>
  </view>

  <!-- Page header card (from config.header) — first block only -->
  <view wx:if="{{surveyHeader && currentBlockIndex === 0}}" class="survey-header-card">
    <text class="survey-header-text"><text wx:for="{{surveyHeaderSegs}}" wx:key="index" class="survey-header-seg {{item.bold ? 'survey-header-bold' : ''}}">{{item.text}}</text></text>
    <view class="survey-header-accent"></view>
  </view>

  <!-- Block intro text (optional) -->
  <view wx:if="{{currentBlock.introText}}" class="block-intro">
    <text>{{currentBlock.introText}}</text>
  </view>

  <!-- Questions in current block -->
  <scroll-view scroll-y class="questions-scroll" scroll-top="{{scrollTop}}">
    <block wx:for="{{visibleQuestions}}" wx:key="id">

      <!-- INTRO type -->
      <view wx:if="{{item.type === 'intro'}}" class="question-card intro-card">
        <text class="intro-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
      </view>

      <!-- STATEMENT type: white card, no options, no coin badge -->
      <view wx:elif="{{item.type === 'statement'}}" class="question-card statement-card">
        <text class="question-text statement-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
      </view>

      <!-- SINGLE SELECT -->
      <view wx:elif="{{item.type === 'single_select'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <radio-group bindchange="onSingleSelect" data-field="{{item.field}}" data-qid="{{item.id}}">
          <label wx:for="{{item.options}}" wx:for-item="opt" wx:key="value" class="option-row">
            <radio value="{{opt.value}}" checked="{{answers[item.field] === opt.value}}" color="#419f8c"/>
            <text class="option-label">{{opt.label}}</text>
          </label>
        </radio-group>
      </view>

      <!-- MULTI SELECT -->
      <view wx:elif="{{item.type === 'multi_select'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <view wx:for="{{item.options}}" wx:for-item="opt" wx:key="value" class="option-row"
              bindtap="onMultiSelect" data-field="{{item.field}}" data-value="{{opt.value}}" data-exclusive="{{opt.exclusive}}">
          <checkbox value="{{opt.value}}"
                    checked="{{multiAnswers[item.field][opt.value]}}"
                    color="#419f8c" />
          <text class="option-label">{{opt.label}}</text>
        </view>
      </view>

      <!-- SLIDER -->
      <view wx:elif="{{item.type === 'slider'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <view class="slider-labels">
          <text class="slider-min-label">{{item.minLabel}} ({{item.min}})</text>
          <text class="slider-max-label">{{item.maxLabel}} ({{item.max}})</text>
        </view>
        <slider min="{{item.min}}" max="{{item.max}}" step="1"
                value="{{answers[item.field] !== undefined ? answers[item.field] : -1}}"
                show-value block-color="#419f8c" active-color="#419f8c"
                bindchange="onSliderChange" data-field="{{item.field}}" data-qid="{{item.id}}" />
        <view wx:if="{{answers[item.field] === undefined}}" class="slider-placeholder">
          <text>请拖动滑块作答</text>
        </view>
      </view>

      <!-- MATRIX -->
      <view wx:elif="{{item.type === 'matrix'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <view class="matrix-wrap">
          <!-- Header row -->
          <view class="matrix-header-row">
            <view class="matrix-row-label"></view>
            <view wx:for="{{item.scaleLabels}}" wx:for-item="lbl" wx:key="index" class="matrix-col-label">
              <text>{{lbl}}</text>
            </view>
          </view>
          <!-- Data rows -->
          <view wx:for="{{item.rows}}" wx:for-item="row" wx:key="id" class="matrix-data-row">
            <view class="matrix-row-label"><text>{{row.label}}</text></view>
            <view wx:for="{{item.scaleValues}}" wx:for-item="val" wx:key="index" class="matrix-cell"
                  bindtap="onMatrixSelect" data-rowfield="{{row.field}}" data-value="{{val}}" data-qid="{{item.id}}">
              <view class="matrix-radio {{matrixAnswers[row.field] === val ? 'matrix-radio-selected' : ''}}"></view>
            </view>
          </view>
        </view>
      </view>

      <!-- DROPDOWN -->
      <view wx:elif="{{item.type === 'dropdown'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <picker mode="selector" range="{{item.options}}"
                bindchange="onDropdownChange" data-field="{{item.field}}" data-qid="{{item.id}}"
                value="{{dropdownIndices[item.field] !== undefined ? dropdownIndices[item.field] : pickerDefaults[item.field]}}">
          <view class="picker-display">
            <text class="{{dropdownIndices[item.field] !== undefined ? 'picker-selected' : 'picker-placeholder'}}">
              {{dropdownIndices[item.field] !== undefined ? item.options[dropdownIndices[item.field]] : '请选择'}}
            </text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <!-- OPEN TEXT -->
      <view wx:elif="{{item.type === 'open_text'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <textarea class="open-text-input" placeholder="请在此输入您的回答"
                  bindinput="onTextInput" data-field="{{item.field}}" data-qid="{{item.id}}"
                  value="{{answers[item.field] || ''}}" auto-height />
      </view>

      <!-- TOKEN ALLOCATION -->
      <view wx:elif="{{item.type === 'token_allocation'}}" class="question-card">
        <view wx:if="{{coinValues[item.id]}}" class="coin-badge">+{{coinValues[item.id]}}</view>
        <text class="question-text"><text wx:for="{{item.textSegs}}" wx:for-item="seg" wx:key="index" class="q-seg {{seg.bold ? 'q-seg-bold' : ''}}">{{seg.text}}</text></text>
        <view class="alloc-rows">
          <view wx:for="{{item.categories}}" wx:for-item="cat" wx:key="id" class="alloc-row">
            <view class="alloc-label-wrap">
              <text class="alloc-label">{{cat.label}}</text>
              <text wx:if="{{devMode && item.randomiseCategories && !cat.pinBottom}}" class="alloc-rand-tag">🔀 随机</text>
              <text wx:if="{{devMode && cat.pinBottom}}" class="alloc-rand-tag alloc-pin-tag">📌 固定</text>
            </view>
            <view class="alloc-controls">
              <view class="alloc-btn {{(allocAnswers[item.id][cat.field] || 0) === 0 ? 'alloc-btn-disabled' : ''}}"
                    bindtap="onAllocMinus" data-qid="{{item.id}}" data-cat="{{cat.field}}">−</view>
              <text class="alloc-count">{{allocAnswers[item.id][cat.field] || 0}}</text>
              <view class="alloc-btn {{(allocTotals[item.id] || 0) >= item.totalTokens ? 'alloc-btn-disabled' : ''}}"
                    bindtap="onAllocPlus" data-qid="{{item.id}}" data-cat="{{cat.field}}">+</view>
            </view>
          </view>
        </view>
        <view class="alloc-total-row {{(allocTotals[item.id] || 0) === item.totalTokens ? 'alloc-total-done' : ''}}">
          <text>已分配 {{allocTotals[item.id] || 0}} / {{item.totalTokens}}</text>
        </view>
      </view>

    </block>
  </scroll-view>

  <!-- Navigation buttons -->
  <view class="nav-buttons">
    <button wx:if="{{currentBlockIndex > 0}}" class="btn-back" bindtap="onPrevBlock">上一页</button>
    <button wx:if="{{!isLastBlock}}" class="btn-next {{canAdvance ? '' : 'btn-disabled'}}"
            bindtap="onNextBlock" disabled="{{!canAdvance}}">下一页</button>
    <view wx:if="{{isLastBlock}}" class="coin-badge-wrap btn-submit-wrap">
      <button class="btn-submit {{canAdvance ? '' : 'btn-disabled'}}"
              bindtap="onSubmit" disabled="{{!canAdvance}}">提交</button>
      <view wx:if="{{surveyLastBlockCoins}}" class="coin-badge">+{{surveyLastBlockCoins}}</view>
    </view>
  </view>

</view>
