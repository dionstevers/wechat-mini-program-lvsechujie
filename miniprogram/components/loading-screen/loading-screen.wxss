.ls-screen {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: #419f8c;
  z-index: 1000;
  overflow: hidden;
}

.ls-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  text-align: center;
}

/* ── Globe ─────────────────────────────────────────────────────────────── */
/* Mirrors the original index/loading globe markup exactly: bottom-image at
   z-index:1, top-image at z-index:2 with a small offset so the rim aligns. */
.ls-globe {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ls-globe-bottom {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 1;
  animation: ls-grayscale 1.6s steps(2, end) infinite;
}

.ls-globe-top {
  position: absolute;
  top: -7rpx;
  left: -1rpx;
  width: 100%;
  height: 100%;
  z-index: 2;
  animation: ls-grayscale 1.6s steps(2, end) infinite;
}

@keyframes ls-grayscale {
  0%   { filter: grayscale(0%); }
  50%  { filter: grayscale(100%); }
  100% { filter: grayscale(0%); }
}

/* ── Title + dots ──────────────────────────────────────────────────────── */
.ls-title-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
}

.ls-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

.ls-dot {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-left: 4rpx;
  opacity: 0;
}

/* All three dots share one 1.6s cycle. Dot N snaps on at N/4 of the cycle
   and stays on through the end; at the cycle boundary they all snap off at
   once. steps(1, end) ensures hard, robotic transitions. */
.ls-dot-1 { animation: ls-dot-1 1.6s steps(1, end) infinite; }
.ls-dot-2 { animation: ls-dot-2 1.6s steps(1, end) infinite; }
.ls-dot-3 { animation: ls-dot-3 1.6s steps(1, end) infinite; }

@keyframes ls-dot-1 {
  0%   { opacity: 0; }
  25%  { opacity: 1; }
  100% { opacity: 1; }
}
@keyframes ls-dot-2 {
  0%   { opacity: 0; }
  50%  { opacity: 1; }
  100% { opacity: 1; }
}
@keyframes ls-dot-3 {
  0%   { opacity: 0; }
  75%  { opacity: 1; }
  100% { opacity: 1; }
}

/* ── Subtitle ──────────────────────────────────────────────────────────── */
.ls-sub {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.6;
  max-width: 600rpx;
}

.ls-sub-bold {
  color: #f9bc60;
  font-weight: bold;
}
