.wb-bar {
  position: fixed;
  top: calc(20rpx + env(safe-area-inset-top));
  left: 20rpx;
  right: 20rpx;
  z-index: 940;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.7);
  border: 1rpx solid rgba(249, 188, 96, 0.6);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.3);
}

.wb-icon {
  font-size: 30rpx;
  line-height: 1;
}

.wb-text {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  line-height: 1.4;
}

.wb-dismiss {
  flex-shrink: 0;
  padding: 6rpx 18rpx;
  background: #f9bc60;
  color: #2a1a00;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 30rpx;
  letter-spacing: 1rpx;
}
