.coin-counter {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  margin: 0 auto;
}

.coin-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.coin-info {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 8rpx;
}

.coin-total {
  font-size: 28rpx;
  font-weight: bold;
  color: #f9bc60;
}

.coin-yuan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}
