.dev-banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: #cc4400;
  padding: 6rpx 20rpx;
  text-align: center;
  transition: opacity 0.2s ease;
}

.dev-banner-dimmed {
  opacity: 0.15;
}

.dev-banner-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 1px;
}
