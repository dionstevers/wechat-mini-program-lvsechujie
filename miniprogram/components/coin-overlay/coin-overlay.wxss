.coin-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 950;
  pointer-events: none;
  background: transparent;
}

.coin-mover {
  width: 130rpx;
  height: 130rpx;
  pointer-events: auto;
  position: relative;
  overflow: visible;
}

.coin-bubble {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  border: 3rpx solid #f9bc60;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.22);
  box-sizing: border-box;
}

.coin-overlay-icon {
  font-size: 32rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.coin-overlay-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1;
}

.coin-overlay-yuan {
  font-size: 20rpx;
  color: #888;
  line-height: 1;
  margin-top: 4rpx;
}

@keyframes coin-pulse {
  0%   { transform: scale(1);    box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.22); }
  35%  { transform: scale(1.22); box-shadow: 0 0 32rpx rgba(249, 188, 96, 0.9); }
  100% { transform: scale(1);    box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.22); }
}

.coin-bubble.pulsing {
  animation: coin-pulse 0.55s ease-out;
}

.coin-pop {
  position: absolute;
  top: 50%;
  left: 50%;
  font-size: 36rpx;
  font-weight: bold;
  color: #f9bc60;
  text-shadow: 0 0 10rpx rgba(249, 188, 96, 0.95), 0 2rpx 4rpx rgba(0, 0, 0, 0.4);
  pointer-events: none;
  white-space: nowrap;
  animation: coin-rise 0.9s ease-out forwards;
  z-index: 5;
}

@keyframes coin-rise {
  0%   { opacity: 0;   transform: translate(-50%, -40%) scale(0.6); }
  15%  { opacity: 1;   transform: translate(-50%, -60%) scale(1.25); }
  60%  { opacity: 1;   transform: translate(-50%, -130%) scale(1.15); }
  100% { opacity: 0;   transform: translate(-50%, -220%) scale(1.4); }
}
