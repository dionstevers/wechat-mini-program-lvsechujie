<movable-area class="coin-area">
  <movable-view class="coin-mover"
                x="{{x}}" y="{{y}}"
                direction="all" damping="40"
                bindchange="onMove">
    <view class="coin-bubble {{pulsing ? 'pulsing' : ''}}">
      <text class="coin-overlay-icon">💰</text>
      <text class="coin-overlay-value">{{coins}}</text>
      <text class="coin-overlay-yuan">¥{{yuan}}</text>
    </view>
    <view wx:if="{{popVisible}}" class="coin-pop" key="{{popKey}}">+{{popValue}} 💰</view>
  </movable-view>
</movable-area>
