.feed-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

/* ── Video overlay ─────────────────────────────────────────────────────── */
.video-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #000;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.treatment-video {
  width: 100%;
  height: 100%;
}

.btn-continue {
  position: absolute;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 80rpx;
  border: none;
}

/* ── Feed ──────────────────────────────────────────────────────────────── */
.feed-scroll {
  flex: 1;
  overflow: hidden;
}

.feed-header {
  background: #419f8c;
  padding: 40rpx 40rpx 50rpx;
}

.feed-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.feed-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.articles-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.article-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
}

.article-card:active {
  opacity: 0.9;
}

.article-thumb {
  width: 100%;
  height: 280rpx;
}

.article-info {
  padding: 30rpx;
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #012644;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.article-lead {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Bottom nav (visual only) ──────────────────────────────────────────── */
.bottom-nav {
  display: flex;
  flex-direction: row;
  height: 100rpx;
  background: #419f8c;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  gap: 4rpx;
}

.nav-item.active {
  color: #f9bc60;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}
