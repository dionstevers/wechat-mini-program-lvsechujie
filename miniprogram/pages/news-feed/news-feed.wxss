.feed-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

/* ── Feed content wrapper ───────────────────────────────────────────────── */
.feed-content {
  display: flex;
  flex-direction: column;
  height: 100vh;
  transition: filter 0.3s ease;
}

.feed-blurred {
  filter: blur(6px);
  pointer-events: none;
}

/* ── Video overlay base ─────────────────────────────────────────────────── */
.video-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* Full-screen mode */
.video-overlay-fullscreen {
  background: #000;
}

.video-fullscreen-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.video-fullscreen-inner .treatment-video {
  width: 100%;
  height: 100%;
}

/* Modal (overlay) mode */
.video-overlay-modal {
  background: rgba(0, 0, 0, 0.55);
  padding: 40rpx;
}

.video-modal {
  width: 100%;
  background: #000;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.6);
}

.treatment-video {
  width: 100%;
  aspect-ratio: 16 / 9;
  display: block;
}

.btn-continue {
  display: block;
  margin: 24rpx auto 0;
  background: #f9bc60;
  color: #2a1a00;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 80rpx;
  border: none;
  width: auto;
}

/* ── Feed ──────────────────────────────────────────────────────────────── */
.feed-scroll {
  flex: 1;
  overflow: hidden;
}

.feed-header {
  position: relative;
  background: #419f8c;
  padding: 20rpx 40rpx 24rpx;
}

.feed-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.article-prompt {
  position: absolute;
  top: 0;
  right: 30rpx;
  padding: 12rpx 22rpx;
  background: rgba(249, 188, 96, 0.18);
  border: 1rpx solid rgba(249, 188, 96, 0.45);
  border-top: none;
  border-radius: 0 0 14rpx 14rpx;
  white-space: nowrap;
}

.article-prompt-seg {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.35;
  white-space: nowrap;
}

.article-prompt-bold {
  color: #f9bc60;
  font-weight: bold;
}

.feed-subtitle {
  display: block;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.85);
}

.feed-subtitle-bold {
  color: #f9bc60;
  font-weight: bold;
}

.articles-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.article-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
}

.article-card:active {
  opacity: 0.9;
}

.article-thumb {
  width: 100%;
  height: 280rpx;
}

.article-info {
  padding: 30rpx;
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #012644;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.article-lead {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Bottom nav (visual only) ──────────────────────────────────────────── */
.bottom-nav {
  display: flex;
  flex-direction: row;
  height: 100rpx;
  background: #419f8c;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  gap: 4rpx;
}

.nav-item.active {
  color: #f9bc60;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}
