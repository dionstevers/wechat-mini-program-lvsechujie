.feed-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

/* ── Feed content wrapper ───────────────────────────────────────────────── */
.feed-content {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transition: filter 0.3s ease;
}

.feed-blurred {
  filter: blur(6px);
  pointer-events: none;
}

/* ── Video overlay base ─────────────────────────────────────────────────── */
.video-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* Full-screen mode */
.video-overlay-fullscreen {
  background: #000;
}

.video-fullscreen-inner {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.video-fullscreen-inner .treatment-video {
  width: 100%;
  height: 100%;
}

/* Modal (overlay) mode */
.video-overlay-modal {
  background: rgba(0, 0, 0, 0.55);
  padding: 40rpx;
}

.video-modal {
  width: 100%;
  background: transparent;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 16rpx 60rpx rgba(0, 0, 0, 0.6);
}

.treatment-video {
  width: 100%;
  aspect-ratio: 16 / 9;
  display: block;
}

.btn-continue {
  display: block;
  margin: 32rpx auto 0;
  background: #f9bc60;
  color: #2a1a00;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 80rpx;
  border: none;
  width: auto;
  opacity: 0;
  transform: translateY(12rpx);
  pointer-events: none;
  transition: opacity 0.4s ease, transform 0.4s ease;
}

.btn-continue.btn-continue-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* ── Feed ──────────────────────────────────────────────────────────────── */
.feed-scroll {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  overflow: hidden;
}

.feed-header {
  position: relative;
  background: #419f8c;
  padding: 15rpx 40rpx 24rpx;
}

.feed-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.article-prompt {
  position: absolute;
  top: 0;
  right: 30rpx;
  padding: 12rpx 22rpx;
  background: rgba(249, 188, 96, 0.18);
  border: 1rpx solid rgba(249, 188, 96, 0.45);
  border-top: none;
  border-radius: 0 0 14rpx 14rpx;
  white-space: nowrap;
}

.article-prompt-seg {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.35;
  white-space: nowrap;
}

.article-prompt-bold {
  color: #f9bc60;
  font-weight: bold;
}

.feed-subtitle {
  display: block;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.85);
}

.feed-subtitle-bold {
  color: #f9bc60;
  font-weight: bold;
}

.articles-list {
  flex: 1;
  min-height: 0;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.article-card {
  flex: 1 1 0;
  min-height: 0;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
}

.article-card:active {
  opacity: 0.9;
}

.article-thumb {
  width: 100%;
  flex: 0 0 300rpx;
  height: 300rpx;
}

.article-info {
  flex: 1;
  min-height: 0;
  padding: 16rpx 24rpx;
}

.article-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: bold;
  color: #012644;
  line-height: 1.4;
  height: 84rpx;
  margin-bottom: 10rpx;
}

.article-lead {
  display: -webkit-box;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Bottom nav (visual only) ──────────────────────────────────────────── */
.bottom-nav {
  display: flex;
  flex-direction: row;
  height: 100rpx;
  background: #419f8c;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  gap: 4rpx;
}

.nav-item.active {
  color: #f9bc60;
}

.nav-icon {
  width: 44rpx;
  height: 44rpx;
}

/* ── Exit-survey loading overlay ───────────────────────────────────────── */
.loading-screen {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, #97baaf 0%, #5fa897 50%, #419f8c 100%);
  overflow: hidden;
  z-index: 1000;
}

.loading-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
}
.loading-screen .decor-a {
  width: 360rpx; height: 360rpx;
  top: -120rpx; left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.loading-screen .decor-b {
  width: 420rpx; height: 420rpx;
  top: 200rpx; right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.loading-screen .decor-c {
  width: 320rpx; height: 320rpx;
  bottom: 220rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.loading-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  text-align: center;
}

.loading-spinner {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #f9bc60;
  animation: loading-spin 0.9s linear infinite;
  margin-bottom: 48rpx;
}

@keyframes loading-spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-line {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.5;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.loading-sub {
  display: block;
  color: rgba(255, 255, 255, 0.88);
  font-size: 30rpx;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.loading-highlight {
  color: #f9bc60;
  font-weight: bold;
}
