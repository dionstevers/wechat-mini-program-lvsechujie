<view class="feed-page">
  <dev-banner />
  <coin-overlay />

  <!-- ── Feed content (blurred when video overlay active) ─────────────── -->
  <view class="feed-content {{showOverlay && !videoFullscreen ? 'feed-blurred' : ''}}">

    <view class="feed-scroll">
      <view class="feed-header">
        <view class="article-prompt">
          <text wx:for="{{articlePromptSegs}}" wx:for-item="seg" wx:key="index" class="article-prompt-seg {{seg.bold ? 'article-prompt-bold' : ''}}">{{seg.text}}</text>
        </view>
        <text class="feed-title">{{feedTitle}}</text>
        <text class="feed-subtitle"><text wx:for="{{feedSubtitleSegs}}" wx:key="index" class="feed-subtitle-seg {{item.bold ? 'feed-subtitle-bold' : ''}}">{{item.text}}</text></text>
      </view>

      <view class="articles-list">
        <view wx:for="{{displayArticles}}" wx:key="id"
              class="article-card"
              bindtap="onArticleTap"
              data-article-id="{{item.id}}">
          <image class="article-thumb" src="{{item.thumbnail}}" mode="aspectFill" />
          <view class="article-info">
            <text class="article-title">{{item.title}}</text>
            <text class="article-lead">{{item.lead}}</text>
          </view>
        </view>
      </view>
    </view>

    <tab-bar id="tabBar" />


  </view>

  <!-- ── Exit-survey loading overlay (shown right before redirect) ────── -->
  <loading-screen
    wx:if="{{showExitLoading}}"
    title="您正在前往结束问卷"
    subSegs="{{exitLoadingSegs}}"
  />

  <!-- ── Video overlay (conditions 1–3) ──────────────────────────────── -->
  <view wx:if="{{showOverlay}}" class="video-overlay {{videoFullscreen ? 'video-overlay-fullscreen' : 'video-overlay-modal'}}">
    <view class="{{videoFullscreen ? 'video-fullscreen-inner' : 'video-modal'}}">
      <video
        id="treatment-video"
        src="{{videoSrc}}"
        autoplay
        controls="{{false}}"
        show-play-btn="{{false}}"
        show-center-play-btn="{{false}}"
        show-mute-btn="{{false}}"
        show-fullscreen-btn="{{false}}"
        objectFit="contain"
        class="treatment-video"
        bindended="onVideoEnded"
        binderror="onVideoError"
      />
    </view>
    <button class="btn-continue {{showContinueBtn ? 'btn-continue-visible' : ''}}" bindtap="onContinue" disabled="{{!showContinueBtn}}">继续</button>
  </view>

</view>
