<view class="page-background" style="background: {{background}};">
  <view class="top-image-section">
    <image class="merch-image" src="{{merch.image}}"></image>
  </view>
  <view class="merch-info">
    <view class="merch-title">{{merch.title}}</view>
    <view class="merch-price">
      <image class="price-icon" src="../../asset/img/exchange_light.png"></image>
      <text class="price-text">{{merch.price}}</text>
    </view>
    <view class="merch-description">{{merch.description}}</view>
    <view class="merch-long-description">{{merch.longDescription}}</view>
    <!-- <button class="claim-button" bindtap="claimMerch" open-type="getRealtimePhoneNumber" bindgetrealtimephonenumber="getrealtimephonenumber">
      <image class="exchange-icon" src="../../asset/img/exchange.png" style="position: relative; left: -38rpx; top: 5rpx"></image>
      {{merch.price}} 兑换
    </button> -->
    <button class="claim-button" open-type="getRealtimePhoneNumber" bindgetrealtimephonenumber="getrealtimephonenumber">
      <image class="exchange-icon" src="../../asset/img/exchange.png" style="position: relative; left: -38rpx; top: 5rpx"></image>
      {{merch.price}} 兑换
    </button>


  </view>
</view>
