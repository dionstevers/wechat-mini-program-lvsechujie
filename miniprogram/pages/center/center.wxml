<wxs src="../home/home.wxs" module="m1"></wxs>

<view class="center-page">
  <view class="landing-decor decor-a"></view>
  <view class="landing-decor decor-b"></view>
  <view class="landing-decor decor-c"></view>

  <view class="center-content">
    <!-- Reward card -->
    <view class="reward-card">
      <text class="reward-emoji">🪙</text>
      <text class="reward-coins">{{coins}}</text>
      <text class="reward-label">当前奖励 · 金币</text>
      <text class="reward-yuan">≈ ¥{{yuan}}</text>
    </view>

    <!-- Summary stats -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{totalTrips}}</text>
        <text class="stat-label">行程次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{totalCarbG}}</text>
        <text class="stat-label">省碳量 (g)</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{totalDurationMin}}</text>
        <text class="stat-label">总时长 (分)</text>
      </view>
    </view>

    <!-- Records list -->
    <view class="records-section">
      <text class="records-title">最近行程</text>

      <view wx:if="{{tripRecords.length > 0}}" class="records-list">
        <view wx:for="{{tripRecords}}" wx:key="_id" class="record-item">
          <image
            class="record-icon"
            src="{{ m1.getTransportImage(item.calcTransport) }}"
            mode="aspectFit"
          />
          <view class="record-body">
            <text class="record-transport">{{item.transport}}</text>
            <text class="record-meta">
              {{ m1.convertStamp(item.endTime - item.date, "duration") }} · 省碳 {{item.carbSum}} g
            </text>
            <text wx:if="{{item.purpose}}" class="record-purpose">出行目的：{{item.purpose}}</text>
          </view>
        </view>
      </view>

      <view wx:elif="{{loaded}}" class="empty-state">
        <text class="empty-emoji">🌿</text>
        <text class="empty-line">暂无行程记录</text>
        <text class="empty-sub">前往「行程记录」开启低碳出行吧！</text>
      </view>

      <view wx:else class="loading-state">
        <view class="dot-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
    </view>
  </view>
</view>

<tab-bar id="tabBar" selected="{{2}}"></tab-bar>
