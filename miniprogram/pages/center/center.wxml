  <view class='heat-con'>
    <!-- <view class="heat-title">
      低碳热力图 30天
    </view> -->
    <view class="image-con">
      <image src="../../asset/img/heatmap-fake.png" mode="aspectFill" />
    </view>
  </view>
  <view class='menu-bar sta'>出行统计
    <!-- <text>
      步行 骑行 公交车 地铁 汽车 网约车/出租车 飞机 火车
    </text> -->
  </view>
  <view class='menu-bar'>我的信息</view>
  <view class='menu-bar'>授权管理</view>
  <view class='menu-bar'>关于小程序</view>
</view>