.center-page {
  position: relative;
  min-height: 100vh;
  padding: 60rpx 40rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #97baaf;
  overflow-x: hidden;
}

/* Decor blobs (mirrors landing/consent style) */
.landing-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
}
.decor-a {
  width: 360rpx; height: 360rpx;
  top: -120rpx; left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.decor-b {
  width: 420rpx; height: 420rpx;
  top: 200rpx; right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.decor-c {
  width: 320rpx; height: 320rpx;
  bottom: 220rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.center-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ── Reward card ──────────────────────────────────────────────────────── */
.reward-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  padding: 48rpx 36rpx 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
}

.reward-emoji {
  font-size: 88rpx;
  line-height: 1;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 6rpx 18rpx rgba(0, 0, 0, 0.45));
}

.reward-coins {
  font-size: 88rpx;
  font-weight: bold;
  color: #f9bc60;
  line-height: 1.1;
  letter-spacing: 2rpx;
}

.reward-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

.reward-yuan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

/* ── Stats row ────────────────────────────────────────────────────────── */
.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 24rpx;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-value {
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.18);
}

/* ── Records section ──────────────────────────────────────────────────── */
.records-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.records-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 1rpx;
  padding-left: 8rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.record-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-transport {
  font-size: 28rpx;
  font-weight: bold;
  color: #012644;
}

.record-meta {
  font-size: 24rpx;
  color: #666;
}

.record-purpose {
  font-size: 22rpx;
  color: #888;
}

/* ── Empty / loading states ───────────────────────────────────────────── */
.empty-state, .loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 30rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx dashed rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-line {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.92);
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.dot-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #f9bc60;
  animation: center-spin 0.9s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes center-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── Reward-paid banner (top of center after payout) ──────────────────── */
.reward-paid-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  background: rgba(95, 168, 151, 0.18);
  border: 2rpx solid rgba(95, 168, 151, 0.55);
  border-radius: 20rpx;
}

.reward-paid-icon {
  font-size: 56rpx;
  line-height: 1;
}

.reward-paid-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reward-paid-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #d8f7ec;
}

.reward-paid-txn,
.reward-paid-when {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  font-family: monospace;
}
