<view class="consent-page">
  <dev-banner />
  <welcome-banner class="welcome-banner-host" />
  <home-cap-btn bind:nudge="onHomeNudge" />
  <coin-overlay />

  <view class="landing-decor decor-a"></view>
  <view class="landing-decor decor-b"></view>
  <view class="landing-decor decor-c"></view>

  <view class="consent-body">
    <view class="consent-hero">
      <text class="consent-emoji">📋</text>
    </view>

    <view class="consent-card consent-card-header">
      <text class="consent-header">
        <text wx:for="{{content.topHeader.segments}}" wx:for-item="seg" wx:key="*this" class="seg-{{seg.style}}">{{seg.text}}</text>
      </text>
      <view class="consent-accent"></view>
    </view>

    <view class="consent-card consent-card-body">
      <view class="consent-text">
        <text class="section-title">{{content.title}}</text>

        <block wx:for="{{content.sections}}" wx:for-item="section" wx:for-index="si" wx:key="si">
          <text class="section-heading">{{section.heading}}</text>
          <view class="section-body" wx:for="{{section.paragraphs}}" wx:for-item="para" wx:for-index="pi" wx:key="pi">
            <text wx:for="{{para.segments}}" wx:for-item="seg" wx:for-index="gi" wx:key="gi" class="seg-{{seg.style}}">{{seg.text}}</text>
          </view>
        </block>
      </view>
    </view>

    <view wx:if="{{devMode && contentEn}}" class="consent-card dev-translation">
      <view class="dev-translation-tag">
        <text class="dev-translation-tag-text">DEV ONLY · English translation</text>
      </view>
      <text class="section-title dev-translation-title">{{contentEn.title}}</text>
      <block wx:for="{{contentEn.sections}}" wx:for-item="section" wx:for-index="si" wx:key="si">
        <text class="section-heading dev-translation-heading">{{section.heading}}</text>
        <view class="section-body dev-translation-body" wx:for="{{section.paragraphs}}" wx:for-item="para" wx:for-index="pi" wx:key="pi">
          <text wx:for="{{para.segments}}" wx:for-item="seg" wx:for-index="gi" wx:key="gi" class="seg-{{seg.style}}">{{seg.text}}</text>
        </view>
      </block>
    </view>

    <view class="bottom-spacer"></view>
  </view>

  <view class="consent-buttons">
    <button class="btn-disagree" bindtap="onDisagree" disabled="{{submitting}}">{{content.buttons.disagree}}</button>
    <view class="coin-badge-wrap btn-agree-wrap">
      <button class="btn-agree" bindtap="onAgree" disabled="{{submitting}}" loading="{{submitting}}">{{content.buttons.agree}}</button>
      <view class="coin-badge">+{{btnCoins}}</view>
    </view>
  </view>
</view>
