<view class="consent-page">
  <dev-banner />

  <view class="consent-body">
    <view class="welcome-banner">
      <text class="app-name">{{content.welcome.appName}}</text>
      <text class="welcome-text">{{content.welcome.welcomeText}}</text>
    </view>

    <view class="consent-text">
      <view class="section-body" wx:for="{{content.intro}}" wx:for-item="para" wx:for-index="pi" wx:key="pi">
        <text wx:for="{{para.segments}}" wx:for-item="seg" wx:for-index="si" wx:key="si" class="seg-{{seg.style}}">{{seg.text}}</text>
      </view>

      <text class="section-title">{{content.title}}</text>

      <block wx:for="{{content.sections}}" wx:for-item="section" wx:for-index="si" wx:key="si">
        <text class="section-heading">{{section.heading}}</text>
        <view class="section-body" wx:for="{{section.paragraphs}}" wx:for-item="para" wx:for-index="pi" wx:key="pi">
          <text wx:for="{{para.segments}}" wx:for-item="seg" wx:for-index="gi" wx:key="gi" class="seg-{{seg.style}}">{{seg.text}}</text>
        </view>
      </block>
    </view>

    <view class="bottom-spacer"></view>
  </view>

  <view class="consent-buttons">
    <button class="btn-disagree" bindtap="onDisagree">{{content.buttons.disagree}}</button>
    <button class="btn-agree" bindtap="onAgree">{{content.buttons.agree}}</button>
  </view>
</view>
