.dev-banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: #cc4400;
  padding: 6rpx 20rpx;
  text-align: center;
}

.dev-banner-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 1px;
}

.consent-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #00022a 0%, #009797 100%);
}

.consent-body {
  padding: 40rpx 40rpx 0;
}

.welcome-banner {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.app-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #f9bc60;
  margin-bottom: 12rpx;
}

.welcome-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.consent-text {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.section-heading {
  font-size: 28rpx;
  font-weight: bold;
  color: #f9bc60;
  margin-top: 32rpx;
  margin-bottom: 12rpx;
}

.section-body {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.highlight {
  color: #f9bc60;
  font-weight: bold;
}

.bold {
  font-weight: bold;
  color: #fff;
}

.bottom-spacer {
  height: 180rpx;
}

.consent-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(0, 2, 42, 0.95);
  gap: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.btn-disagree {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.8);
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  padding: 0;
}

.btn-agree {
  flex: 2;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  padding: 0;
}
