.consent-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #97baaf 0%, #5fa897 50%, #419f8c 100%);
  overflow: hidden;
}

/* Decor blobs (mirrors landing page) */
.landing-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
}
.decor-a {
  width: 360rpx; height: 360rpx;
  top: -120rpx; left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.decor-b {
  width: 420rpx; height: 420rpx;
  top: 200rpx; right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.decor-c {
  width: 320rpx; height: 320rpx;
  bottom: 220rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.consent-body {
  position: relative;
  z-index: 1;
  padding: 120rpx 40rpx 0;
}

.consent-hero {
  display: flex;
  justify-content: center;
  margin: 0 0 28rpx;
  animation: hero-float 3.2s ease-in-out infinite;
}

.consent-emoji {
  font-size: 200rpx;
  line-height: 1;
  filter: drop-shadow(0 6rpx 18rpx rgba(0, 0, 0, 0.45));
}

@keyframes hero-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-12rpx); }
}

.consent-card {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 28rpx;
}
.consent-card-header { padding: 36rpx 32rpx 28rpx; }
.consent-card-body   { padding: 32rpx 28rpx 24rpx; }

.consent-header {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.55;
  letter-spacing: 1rpx;
}

.consent-accent {
  width: 96rpx;
  height: 6rpx;
  background: #f9bc60;
  border-radius: 4rpx;
  margin-top: 24rpx;
}

.consent-text {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  line-height: 1.6;
  text-align: center;
}

.section-heading {
  font-size: 24rpx;
  font-weight: bold;
  color: #f9bc60;
  margin-top: 24rpx;
  margin-bottom: 10rpx;
}

.section-body {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.highlight,
.seg-highlight {
  color: #f9bc60;
  font-weight: bold;
}

.bold,
.seg-bold {
  font-weight: bold;
  color: #fff;
}

.seg-normal {
  /* inherits from .section-body */
}

.bottom-spacer {
  height: 180rpx;
}

.consent-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(0, 2, 42, 0.95);
  gap: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
  z-index: 5;
}

.btn-disagree {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.8);
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  padding: 0;
}

.btn-agree-wrap {
  flex: 2;
  width: auto;
}

.btn-agree {
  width: 100%;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  padding: 0;
}
