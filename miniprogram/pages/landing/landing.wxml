<view class="landing-page">
  <dev-banner />
  <coin-overlay />

  <view class="landing-decor decor-a"></view>
  <view class="landing-decor decor-b"></view>
  <view class="landing-decor decor-c"></view>

  <view class="landing-content">
    <view class="landing-hero">
      <text class="landing-emoji">🌿</text>
    </view>

    <view class="landing-card landing-card-header">
      <text class="landing-header">{{content.header}}</text>
      <view class="landing-accent"></view>
    </view>

    <view class="landing-card landing-card-body">
      <view wx:for="{{content.paragraphs}}" wx:for-item="para" wx:key="pi" class="landing-paragraph">
        <text wx:for="{{para}}" wx:for-item="seg" wx:key="si" class="seg-{{seg.bold ? 'bold' : 'normal'}}">{{seg.text}}</text>
      </view>
    </view>
  </view>

  <view class="landing-footer">
    <!-- <text class="btn-hongbao btn-hongbao-left">🧧</text>
    <text class="btn-hongbao btn-hongbao-right">🧧</text> -->
    <view class="coin-badge-wrap">
      <button class="landing-btn" bindtap="onNext" loading="{{submitting}}">{{content.buttonText}}</button>
      <view class="coin-badge">+{{btnCoins}}</view>
    </view>
  </view>

  <view wx:if="{{rewardModal.show}}" class="reward-modal-mask">
    <view class="reward-modal-box">
      <view wx:for="{{rewardModal.lines}}" wx:for-item="line" wx:key="index" class="reward-modal-line">
        <text wx:for="{{line}}" wx:for-item="seg" wx:key="si" class="seg-{{seg.bold ? 'bold' : 'normal'}} reward-seg">{{seg.text}}</text>
      </view>
      <button class="reward-modal-btn" bindtap="onRewardConfirm">好的</button>
    </view>
  </view>
</view>
