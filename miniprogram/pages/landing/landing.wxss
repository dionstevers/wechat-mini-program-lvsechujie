.landing-page {
  position: relative;
  min-height: 100vh;
  background: #419f8c;
  display: flex;
  flex-direction: column;
  padding: 60rpx 50rpx 40rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* Soft floating decorative blobs */
.landing-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
}
.decor-a {
  width: 360rpx;
  height: 360rpx;
  top: -120rpx;
  left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.decor-b {
  width: 420rpx;
  height: 420rpx;
  top: 200rpx;
  right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.decor-c {
  width: 320rpx;
  height: 320rpx;
  bottom: 220rpx;
  left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.landing-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.landing-hero {
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
  animation: hero-float 3.2s ease-in-out infinite;
}

.landing-emoji {
  font-size: 140rpx;
  line-height: 1;
  filter: drop-shadow(0 6rpx 18rpx rgba(0, 0, 0, 0.45));
}

@keyframes hero-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-14rpx); }
}

.landing-card {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 28rpx;
}
.landing-card:last-of-type { margin-bottom: 0; }
.landing-card-body { padding: 36rpx 36rpx 24rpx; }

.landing-header {
  display: block;
  color: #fff;
  font-size: 42rpx;
  font-weight: bold;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

.landing-accent {
  width: 96rpx;
  height: 6rpx;
  background: #f9bc60;
  border-radius: 4rpx;
  margin: 28rpx 0 0;
}

/* Bold/highlighted spans inside paragraphs */
.seg-normal {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.92);
}
.seg-bold {
  font-size: 30rpx;
  color: #ffd27a;
  font-weight: bold;
}

/* Hongbao flanking the 继续 button */
.btn-hongbao {
  position: absolute;
  font-size: 64rpx;
  pointer-events: none;
  filter: drop-shadow(0 4rpx 10rpx rgba(0, 0, 0, 0.4));
  top: 50%;
}
.btn-hongbao-left {
  left: 8rpx;
  animation: hb-float-a 2.4s ease-in-out infinite;
}
.btn-hongbao-right {
  right: 8rpx;
  animation: hb-float-b 2.4s ease-in-out infinite 0.6s;
}

@keyframes hb-float-a {
  0%, 100% { transform: translateY(-50%) rotate(-10deg); }
  50%      { transform: translateY(-78%) rotate(6deg); }
}
@keyframes hb-float-b {
  0%, 100% { transform: translateY(-50%) rotate(8deg); }
  50%      { transform: translateY(-78%) rotate(-10deg); }
}

.landing-paragraph {
  display: block;
  color: rgba(255, 255, 255, 0.92);
  font-size: 30rpx;
  line-height: 1.85;
  margin-bottom: 24rpx;
}
.landing-paragraph:last-child { margin-bottom: 0; }

.landing-footer {
  position: relative;
  z-index: 1;
  padding: 30rpx 100rpx calc(20rpx + env(safe-area-inset-bottom));
}

.landing-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ffd27a 0%, #f9bc60 60%, #e5a23a 100%);
  color: #2a1a00;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  padding: 0;
  border: none;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(249, 188, 96, 0.45), inset 0 -2rpx 0 rgba(0, 0, 0, 0.08);
  letter-spacing: 4rpx;
}
.landing-btn::after { border: none; }

/* Reward modal (kept) */
.reward-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
.reward-modal-box {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.reward-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
  text-align: center;
}
.reward-modal-line {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 12rpx;
}

.reward-seg {
  font-size: 28rpx;
  color: #444;
}

.reward-modal-line .seg-bold {
  font-size: 28rpx;
  color: #e5a23a;
  font-weight: bold;
}
.reward-modal-btn {
  margin-top: 32rpx;
  width: 320rpx;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}
