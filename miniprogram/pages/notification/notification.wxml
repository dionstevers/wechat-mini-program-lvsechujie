<view class="page-background" style="background: {{background}};">
  <view class="container">
    <view class="tabbar">
      <block wx:for="{{tabs}}" wx:key="index">
        <button bindtap="switchTab" data-index="{{index}}" class="tab {{currentTab === index ? 'tab-selected' : ''}}">
          {{item}}
        </button>
      </block>
    </view>
    <view wx:if="{{currentTab == 0}}" class="inbox-container">
      <block wx:if="{{inboxMessages.length > 0}}">
        <block wx:for="{{inboxMessages}}" wx:key="id">
          <view class="message-item {{selectedMessageIndex === index ? 'message-item-selected' : ''}}" data-index="{{index}}" bindtap="toggleMessage">
            <text class="type">信息类型：{{item.type}}</text>
            <text class="time">发送日期：{{item.formattedTime}}</text>
            <text class="original-message">原信息：{{item.message}}</text>
            <text class="stage">处理状态：{{item.stage === 0 ? '处理中' : '已处理'}}</text>
            <text class="response" wx:if="{{item.stage === 1}}">平台回复：{{item.response}}</text>
          </view>
        </block>
      </block>
      <block wx:if="{{inboxMessages.length == 0}}">
        <view class="no-messages">您还没有收到任何消息</view>
      </block>
      <view class="refresh-message">下拉刷新信息</view> <!-- New Line -->
    </view>
    <view wx:if="{{currentTab == 1}}" class="send-message-container">
      <picker mode="selector" range="{{types}}" bindchange="bindPickerChange">
        <view class="picker">{{type || "点击选择发件类型"}}</view>
      </picker>
      <textarea bindinput="bindMessageInput" placeholder="请在此输入..." value="{{message}}"></textarea>
      <button bindtap="submitMessage">发送</button>
    </view>
  </view>
</view>
