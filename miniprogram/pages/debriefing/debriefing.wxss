.debrief-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #00022a 0%, #009797 100%);
}

.debrief-scroll {
  flex: 1;
  overflow: hidden;
}

.debrief-body {
  padding: 40rpx 40rpx 0;
}

.debrief-banner {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f9bc60;
}

.debrief-text {
  display: flex;
  flex-direction: column;
}

.para {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.8;
  margin-bottom: 28rpx;
}

.scroll-hint {
  text-align: center;
  margin-top: 20rpx;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.bottom-spacer {
  height: 180rpx;
}

.debrief-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(0, 2, 42, 0.95);
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.btn-collect {
  width: 100%;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-collect.active {
  background: #f9bc60;
  color: #333;
}

.btn-collect.disabled {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.4);
}
