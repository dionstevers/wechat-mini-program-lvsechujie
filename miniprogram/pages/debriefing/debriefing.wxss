.debrief-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #419f8c;
}

.debrief-scroll {
  flex: 1;
  overflow: hidden;
}

.debrief-body {
  padding: 40rpx 40rpx 0;
}

.debrief-banner {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f9bc60;
}

.debrief-text {
  display: flex;
  flex-direction: column;
}

.para {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.8;
  margin-bottom: 28rpx;
}

.scroll-hint {
  text-align: center;
  margin-top: 20rpx;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.bottom-spacer {
  height: 180rpx;
}

.debrief-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #2e7d6f;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.btn-collect {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 2rpx;
}
.btn-collect::after { border: none; }

.btn-collect.active {
  background: #f9bc60;
  color: #333;
}

.btn-collect.disabled {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.4);
}

/* ── Dev-only English translation ──────────────────────────────────────── */
.dev-translation {
  margin-top: 60rpx;
  padding: 28rpx 32rpx 32rpx;
  border: 1rpx dashed rgba(255, 255, 255, 0.4);
  background: rgba(0, 0, 0, 0.08);
  border-radius: 16rpx;
  opacity: 0.85;
}

.dev-translation-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  margin-bottom: 24rpx;
}

.dev-translation-tag-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 1rpx;
}

.dev-translation-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.92);
  margin-bottom: 16rpx;
}

.dev-translation-para {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.7;
  margin-bottom: 20rpx;
}
