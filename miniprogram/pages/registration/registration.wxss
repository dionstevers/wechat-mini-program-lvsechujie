.reg-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #00022a 0%, #009797 100%);
  padding: 60rpx 40rpx 40rpx;
}

.reg-header {
  margin-bottom: 60rpx;
}

.reg-title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.reg-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.7;
}

.reg-form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.field-group {
  margin-bottom: 36rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.required {
  color: #e05a4e;
}

.optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
}

.input-error {
  border-color: #e05a4e;
  background: #fff5f5;
}

.error-msg {
  display: block;
  font-size: 24rpx;
  color: #e05a4e;
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 96rpx;
  text-align: center;
  padding: 0;
}

.reward-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
.reward-modal-box {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.reward-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
  text-align: center;
}
.reward-modal-line {
  display: block;
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 12rpx;
}
.reward-modal-btn {
  margin-top: 32rpx;
  width: 320rpx;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}
