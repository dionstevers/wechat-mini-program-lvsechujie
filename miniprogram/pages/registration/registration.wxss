.reg-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #00022a 0%, #009797 100%);
  padding: 60rpx 40rpx 40rpx;
}

.reg-header {
  margin-bottom: 60rpx;
}

.reg-title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.reg-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.7;
}

.reg-form {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.field-group {
  margin-bottom: 36rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.required {
  color: #e05a4e;
}

.optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
}

.input-error {
  border-color: #e05a4e;
  background: #fff5f5;
}

.error-msg {
  display: block;
  font-size: 24rpx;
  color: #e05a4e;
  margin-top: 8rpx;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: #f9bc60;
  color: #333;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 96rpx;
  text-align: center;
  padding: 0;
}
