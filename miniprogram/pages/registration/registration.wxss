.reg-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #00022a 0%, #0a4f6e 55%, #009797 100%);
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow: hidden;
}

/* Decor blobs (mirrors landing/consent) */
.landing-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
}
.decor-a {
  width: 360rpx; height: 360rpx;
  top: -120rpx; left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.decor-b {
  width: 420rpx; height: 420rpx;
  top: 200rpx; right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.decor-c {
  width: 320rpx; height: 320rpx;
  bottom: 220rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.reg-body {
  flex: 1;
  position: relative;
  z-index: 1;
  padding: 80rpx 40rpx 0;
}

.reg-hero {
  display: flex;
  justify-content: center;
  margin: 0 0 28rpx;
  animation: hero-float 3.2s ease-in-out infinite;
}

.reg-emoji {
  font-size: 120rpx;
  line-height: 1;
  filter: drop-shadow(0 6rpx 18rpx rgba(0, 0, 0, 0.45));
}

@keyframes hero-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-12rpx); }
}

.reg-card {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 28rpx;
}
.reg-card-header { padding: 36rpx 32rpx 28rpx; }
.reg-card-body   {
  background: #fff;
  border: none;
  padding: 36rpx 32rpx;
}

.reg-header-text {
  display: block;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1.55;
  letter-spacing: 1rpx;
}

.reg-accent {
  width: 96rpx;
  height: 6rpx;
  background: #f9bc60;
  border-radius: 4rpx;
  margin-top: 24rpx;
}

.reg-form {
  /* now lives inside .reg-card-body */
}

.field-group {
  margin-bottom: 32rpx;
}
.field-group:last-child { margin-bottom: 0; }

.field-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: bold;
}

.required {
  color: #e05a4e;
}

.optional {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
}

.input-error {
  border-color: #e05a4e;
  background: #fff5f5;
}

.error-msg {
  display: block;
  font-size: 24rpx;
  color: #e05a4e;
  margin-top: 8rpx;
}

.reg-footer {
  position: relative;
  z-index: 1;
  padding: 30rpx 50rpx calc(20rpx + env(safe-area-inset-bottom));
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ffd27a 0%, #f9bc60 60%, #e5a23a 100%);
  color: #2a1a00;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 96rpx;
  text-align: center;
  padding: 0;
  box-shadow: 0 8rpx 24rpx rgba(249, 188, 96, 0.45), inset 0 -2rpx 0 rgba(0, 0, 0, 0.08);
  letter-spacing: 4rpx;
}
.btn-submit::after { border: none; }
