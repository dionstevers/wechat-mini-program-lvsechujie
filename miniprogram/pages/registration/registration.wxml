<view class="reg-page">
  <dev-banner />
  <coin-overlay />

  <view class="landing-decor decor-a"></view>
  <view class="landing-decor decor-b"></view>
  <view class="landing-decor decor-c"></view>

  <view class="reg-body">
    <view class="reg-card reg-card-header">
      <text class="reg-header-text"><text wx:for="{{headerSegs}}" wx:for-item="seg" wx:key="index" class="{{seg.bold ? 'reg-seg-bold' : ''}}">{{seg.text}}</text></text>
      <view class="reg-accent"></view>
    </view>

    <view class="reg-card reg-card-body">
      <view class="reg-form">
        <view class="field-group">
          <text class="field-label">{{cfg.labels.phone}} <text class="required">*</text></text>
          <input class="field-input {{errors.phone ? 'input-error' : ''}}"
                 placeholder="{{cfg.placeholders.phone}}"
                 type="number"
                 bindinput="onPhoneInput"
                 value="{{form.phone}}" />
          <text wx:if="{{errors.phone}}" class="error-msg">{{errors.phone}}</text>
        </view>

        <view class="field-group">
          <text class="field-label">{{cfg.labels.wechat}} <text class="optional">{{cfg.labels.optional}}</text></text>
          <input class="field-input"
                 placeholder="{{cfg.placeholders.wechat}}"
                 bindinput="onWechatInput"
                 value="{{form.wechat_id}}" />
        </view>
      </view>
    </view>
  </view>

  <view class="reg-footer">
    <view class="coin-badge-wrap">
      <button class="btn-submit" bindtap="onSubmit" loading="{{submitting}}">{{cfg.buttonText}}</button>
      <view class="coin-badge">+{{btnCoins}}</view>
    </view>
  </view>
</view>
