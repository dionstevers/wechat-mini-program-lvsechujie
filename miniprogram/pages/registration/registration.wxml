<view class="reg-page">
  <dev-banner />
  <coin-overlay />

  <view class="reg-header">
    <text class="reg-title">感谢您同意参与本实验！</text>
    <text class="reg-subtitle">请填写以下信息完成注册。注册成功后您将立即获得初始金币奖励（相当于 ¥1）。</text>
  </view>

  <view class="reg-form">

    <view class="field-group">
      <text class="field-label">姓名 <text class="required">*</text></text>
      <input class="field-input {{errors.name ? 'input-error' : ''}}"
             placeholder="请输入您的姓名"
             bindinput="onNameInput"
             value="{{form.name}}" />
      <text wx:if="{{errors.name}}" class="error-msg">{{errors.name}}</text>
    </view>

    <view class="field-group">
      <text class="field-label">手机号码 <text class="required">*</text></text>
      <input class="field-input {{errors.phone ? 'input-error' : ''}}"
             placeholder="请输入您的手机号码"
             type="number"
             bindinput="onPhoneInput"
             value="{{form.phone}}" />
      <text wx:if="{{errors.phone}}" class="error-msg">{{errors.phone}}</text>
    </view>

    <view class="field-group">
      <text class="field-label">微信号 <text class="optional">（选填）</text></text>
      <input class="field-input"
             placeholder="请输入您的微信号"
             bindinput="onWechatInput"
             value="{{form.wechat_id}}" />
    </view>

  </view>

  <button class="btn-submit" bindtap="onSubmit" loading="{{submitting}}">提交注册</button>

  <view wx:if="{{rewardModal.show}}" class="reward-modal-mask">
    <view class="reward-modal-box">
      <text class="reward-modal-title">🎉 获得金币奖励！</text>
      <text class="reward-modal-line">您已获得 {{rewardModal.coins}} 金币，相当于 ¥{{rewardModal.yuan}}</text>
      <text class="reward-modal-line reward-modal-spacer"> </text>
      <text class="reward-modal-line">继续使用小程序，赚更多金币吧！🧧</text>
      <button class="reward-modal-btn" bindtap="onRewardConfirm">好的</button>
    </view>
  </view>

</view>
