<view class="page-background" style="background: #97baaf">

<view class="header-image">
  <image class="people-image" src="../../asset/img/sus_people.jpg" />
</view>

<view class="selection-bar">
  <button class="tab {{activeTab === 'trip' ? 'active' : ''}}" bindtap="selectTab" data-tab="trip">出行</button>
  <button class="tab {{activeTab === 'record' ? 'active' : ''}}" bindtap="selectTab" data-tab="record">记录</button>
  <button class="tab {{activeTab === 'rank' ? 'active' : ''}}" bindtap="selectTab" data-tab="rank">排名</button>
</view>

<!-- when selectedTab is trip -->
<view wx:if="{{activeTab === 'trip'}}">
  <view wx:if="{{!tracking}}">
    <view class="prompt-container">
      <text class="prompt-title">开始记录你的低碳出行吧</text>
      <text class="prompt-content">点击下方开始记录出行的行程，行程结束后小程序会根据您的出行数据计算省碳量与碳排放</text>
    </view>

    
    <view class="btn-container" bindtap="onTrack">
      <image src="../../asset/img/start.png" class="btn-img"/>
    </view>

  </view>

  <view wx:if="{{tracking}}">
    <view class="record-container">
      <text class="record-duration">00:23:44</text>
      <text class="record-duration-label">记录时长</text>
      <text class="record-start">13:22</text>
      <text class="record-start-label">开始时间</text>

    </view>
      

    <view class="btn-container" bindtap="endTrack">
        <image class="btn-img" src="../../asset/img/stop.png"></image>
    </view>


  </view>
</view>

<!-- when record -->
<view wx:if="{{activeTab === 'record'}}"></view>

<!-- when rank -->
<view wx:if="{{activeTab === 'rank'}}"></view>

</view>
