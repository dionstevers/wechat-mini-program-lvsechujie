<!--pages/home/home.wxml-->
<block wx:if="{{isFromShareTimeline}}">
  <view class="page-background">
    <image class="QRcode" src="https://696c-iluvcarb-0gzvs45g82b57f98-1315168954.tcb.qcloud.la/logo/WechatIMG371.jpg?sign=1618ba30f1437e607318b76aa7335ad7&t=1720952079"></image>
  </view>
</block>

<block wx:else>
  <wxs src="./home.wxs" module="m1"></wxs>
  <view class="page-background" id="home" style="font-family:‘Times New Roman’, Times, serif; background:{{background}};">

    <view>
      <view wx:if="{{ name != '' }}" class="aqi-region">
        {{name}}
      </view>
      <view class="aqi-box" style="background-color: {{aqi<=50 ? '#00e400' : (aqi<=100 ? '#ffff00' : (aqi<=150 ? '#ff7e00' : (aqi <=200 ? '#ff0000' : (aqi<=300 ? '#8f3f97' : '#7e0023'))))}}">
        <view style="color: {{aqi<=50 ? '#00e400' : (aqi<=100 ? '#ffff00' : (aqi<=150 ? '#ff7e00' : (aqi <=200 ? '#ff0000' : (aqi<=300 ? '#8f3f97' : '#7e0023'))))}}; filter: grayscale(1) contrast(999) invert(1); line-height: 7vh">
          <text style="font-size: 30rpx; vertical-align: middle; margin-right: 15rpx">空气质量</text>
          <text style="font-size: 50rpx; vertical-align: middle">{{aqi}} | {{category}}</text>
        </view>
      </view>
      <!--
        <view class="aqi-info" wx:if="{{ name != '' }}">
        您所在的区县：{{name}}
      </view>
      <view class="aqi-info">
        空气质量指数：<text style="color: {{aqi<=50 ? '#00e400' : (aqi<=100 ? '#ffff00' : (aqi<=150 ? '#ff7e00' : (aqi <=200 ? '#ff0000' : (aqi<=300 ? '#8f3f97' : '#7e0023'))))}}">{{aqi}}</text>
      </view>
      <view class="aqi-info">
        空气质量等级：<text style="color: {{aqi<=50 ? '#00e400' : (aqi<=100 ? '#ffff00' : (aqi<=150 ? '#ff7e00' : (aqi <=200 ? '#ff0000' : (aqi<=300 ? '#8f3f97' : '#7e0023'))))}}">{{category}}</text>
      </view>
      -->
      <!-- <privacy-popup bind:agree="agree" bind:disagree="disagree"></privacy-popup>
      <view class="picklist">
        <text>出行方式</text>
        <picker bindchange="bindPickerChange" value="{{index}}" range="{{transportList}}" class="picker-con">
          <view class="picker">
            {{transportList[index]}}
          </view>
          <view class="triangle"></view>
        </picker>
      </view> -->

      <!-- <view class="picklist" wx:if="{{index == 2 || index == 3}}">
        <text>出行人数</text>
        <picker bindchange="bindCapacityChange" value="{{capacity}}" range="{{capacityList}}" class="picker-con">
          <view class="picker">
            {{capacityList[capacity]}}
          </view>
          <view class="triangle"></view>
        </picker>
      </view> -->

      <view class="{{btnClass}}" bindtap="onClickEvent">
        <view wx:if="{{!recordStatus}}">开始</view>
        <view wx:if="{{recordStatus}}">
          <text>{{ m1.convertStamp(duration, "duration") }}</text>
          <text>停止记录</text>
        </view>
      </view>
      <!--
      <view class="list-summary">
      与单人驾车出行相比，今日您已省碳约{{carbonFootprint}} g
      </view>
  -->

      <view class="list-summary" wx:if="{{isRecordEmpty}}">
        今日您没有出行记录
      </view>
      <view class="list-summary" wx:else>
        您今日的上一条出行记录
      </view>

      <view class="list">
        <view wx:for="{{todayRecordList}}" wx:for-index="i" wx:key="i" class="{{m1.classPicker(todayRecordList,i)}}" bindtap="onClickTrackCard">
          <view class="title">时长 <text>{{ m1.convertStamp(item.endTime-item.date, "duration") }} </text> ·
            <text>{{ item.distance > 0 ? item.distance : '未知' }} </text> km · {{ item.transport}}
          </view>
          <view class="content">出行目的：<text>{{ item.purpose }}</text></view>
          <view class="content">
            时间：<text>{{ m1.convertStamp(item.date) }} - {{ m1.convertStamp(item.endTime) }}</text></view>
          <view class="content">省碳量：{{item.carbSum}} g</view>
          <view class="point" wx:if="{{!item.purpose.length || showPoint}}"></view>
        </view>

        <view wx:if="{{!!showSchedules.length}}">
          <view class="heat-title">
            本次出行分析：
          </view>

          <view class="chart">
            <view wx:for="{{showSchedules}}" wx:key="value" class="{{'chart-item ' + item.color}}" style="width: {{ item.percentage }}">{{ item.label + item.percentage }}</view>
          </view>
        </view>

      </view>

      <view class="legend">低碳排行榜</view>
      <view class="summary-line">
        <text>你总共省碳 {{mysaving}} g</text>
        <text>排名: {{myranking}}</text>
      </view>

      <view class="rank-container">
        <block wx:for="{{users}}" wx:key="id">
          <view class="user-item" style="background-color:{{colorStyle === 'RED' ? '#D13A29':'#23cfc9'}}">
            <image class="profile-image" src="{{item.avatar}}" />
            <view class="user-info">
              <view class="user-name">{{item.basicInfo.nickname}}</view>
              <view class="user-stats">
                <view class="carbon-saving">
                  <text class="stat-label">排名:</text>
                  <text class="stat-value">{{item.rank}}</text>
                </view>
                <view class="carbon-saving">
                  <text class="stat-label">省碳:</text>
                  <text class="stat-value">{{item.totalCarbSum}}g</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>



    <modal title="出行方式" confirm-text="确定" cancel-text="取消" hidden="{{transporModalHidden}}" bindconfirm="transporModalConfirm" bindcancel="transporModalCancel" class="modal">
      <view class="picklist">
        <checkbox-group bindchange="bindPickerChange">
          <label class="weui-cell weui-check__label" wx:for="{{endTransportList}}" wx:key="value">
            <view class="weui-cell__hd">
              <checkbox value="{{item.value}}" checked="{{item.checked}}" />
            </view>
            <view class="weui-cell__bd">{{item.name}}</view>
          </label>
        </checkbox-group>
      </view>
      <view class="purpose">出行目的</view>
      <view class="picklist">
        <checkbox-group bindchange="bindPurposeChange">
          <label class="weui-cell weui-check__label" wx:for="{{purposes}}" wx:key="value">
            <view class="weui-cell__hd">
              <checkbox value="{{item.value}}" checked="{{item.checked}}" />
            </view>
            <view class="weui-cell__bd">{{item.name}}</view>
          </label>
        </checkbox-group>
      </view>
    </modal>
  </view>
  <van-dialog id="van-dialog" custom-class="home-dialog" />

</block>