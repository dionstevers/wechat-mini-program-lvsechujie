var pad2 = function (n) { return n < 10 ? "0" + n : "" + n; };

var convertStamp = function (stamp, type) {
  if (stamp !== 0 && !stamp) {
    return "（记录提前终止）";
  }
  if (type == "duration") {
    var totalSec = Math.floor(stamp / 1000);
    var h = Math.floor(totalSec / 3600);
    var m = Math.floor((totalSec % 3600) / 60);
    var s = totalSec % 60;
    return pad2(h) + ":" + pad2(m) + ":" + pad2(s);
  }
  var time = getDate(stamp);
  var month = time.getMonth() + 1;
  var date = time.getDate();
  var hour = pad2(time.getHours());
  var minutes = pad2(time.getMinutes());
  var secondes = pad2(time.getSeconds());
  return month + "月" + date + "日 " + hour + ":" + minutes + ":" + secondes;
};

var classPicker = function (list, index) {
  if (index === 0) {
    return "new listItem";
  } else {
    return "old listItem";
  }
};

var getTransportImage = function (calcTransport) {
  var transports = [
    { label: "步行/跑步", value: "../../asset/img/walking.svg" },
    { label: "骑行", value: "../../asset/img/bike.svg" },
    { label: "汽车(市区)", value: "../../asset/img/car.svg" },
    { label: "汽车(高速公路)", value: "../../asset/img/car.svg" },
    { label: "公交车（市区）", value: "../../asset/img/bus.svg" },
    { label: "公交车（长途）", value: "../../asset/img/bus.svg" },
    { label: "地铁", value: "../../asset/img/subway.svg" },
    { label: "高铁", value: "../../asset/img/train.svg" }
  ];

  var transport = null;

  for (var i = 0; i < transports.length; i++) {
    if (transports[i].label === calcTransport) {
      transport = transports[i];
      break;
    }
  }

  return transport ? transport.value : "../../asset/img/walking.svg";
};

var getActiveClassName = function (arr, label) {
  return arr.indexOf(label) !== -1 ? "active" : "";
};

module.exports.convertStamp = convertStamp;
module.exports.classPicker = classPicker;
module.exports.getTransportImage = getTransportImage;
module.exports.getActiveClassName = getActiveClassName;
