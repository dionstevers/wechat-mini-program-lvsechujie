.loading-screen {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: linear-gradient(180deg, #00022a 0%, #0a4f6e 55%, #009797 100%);
  overflow: hidden;
}

.loading-decor {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(40rpx);
  opacity: 0.55;
}
.decor-a {
  width: 360rpx; height: 360rpx;
  top: -120rpx; left: -100rpx;
  background: radial-gradient(circle, rgba(249, 188, 96, 0.45), transparent 70%);
}
.decor-b {
  width: 420rpx; height: 420rpx;
  top: 200rpx; right: -160rpx;
  background: radial-gradient(circle, rgba(65, 159, 140, 0.55), transparent 70%);
}
.decor-c {
  width: 320rpx; height: 320rpx;
  bottom: 220rpx; left: -120rpx;
  background: radial-gradient(circle, rgba(120, 210, 230, 0.4), transparent 70%);
}

.loading-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  text-align: center;
}

.loading-spinner {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #f9bc60;
  animation: loading-spin 0.9s linear infinite;
  margin-bottom: 48rpx;
}

@keyframes loading-spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-line {
  display: block;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.5;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.loading-sub {
  display: block;
  color: rgba(255, 255, 255, 0.88);
  font-size: 30rpx;
  line-height: 1.6;
}
