.article-page {
  height: 100vh;
  background: #fff;
}

.article-hero {
  width: 100%;
  height: 420rpx;
  display: block;
}

.article-body {
  position: relative;
  margin-top: -32rpx;
  padding: 40rpx 40rpx 80rpx;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.article-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #012644;
  line-height: 1.45;
  margin-bottom: 24rpx;
}

.article-lead {
  display: block;
  font-size: 30rpx;
  color: #555;
  line-height: 1.7;
  font-style: italic;
  padding-left: 20rpx;
  border-left: 6rpx solid #419f8c;
  margin-bottom: 32rpx;
}

.article-divider {
  height: 2rpx;
  background: #e0e0e0;
  margin: 0 0 32rpx;
}

.article-body-text {
  display: block;
  font-size: 30rpx;
  color: #2a2a2a;
  line-height: 1.95;
  letter-spacing: 0.5rpx;
  white-space: pre-wrap;
}

/* ── Dev-only English translation ──────────────────────────────────────── */
.dev-translation {
  margin-top: 60rpx;
  padding: 28rpx 28rpx 32rpx;
  border: 1rpx dashed #c0c8d0;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.015);
  opacity: 0.85;
}

.dev-translation-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}

.dev-translation-tag-text {
  font-size: 20rpx;
  color: #888;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.dev-translation-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #444;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.dev-translation-lead {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  font-style: italic;
  margin-bottom: 20rpx;
}

.dev-translation-divider {
  margin: 0 0 20rpx;
}

.dev-translation-body {
  display: block;
  font-size: 24rpx;
  color: #555;
  line-height: 1.75;
  white-space: pre-wrap;
}
