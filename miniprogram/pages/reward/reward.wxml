<view class="reward-page">
  <dev-banner />
  <welcome-banner class="welcome-banner-host" />
  <home-cap-btn bind:nudge="onHomeNudge" />
  <coin-overlay />

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在计算奖励...</text>
  </view>

  <view wx:else class="reward-content">

    <view class="reward-icon">🎉</view>

    <text class="reward-title">感谢您的参与！</text>
    <text class="reward-subtitle">您已完成本次研究，非常感谢您的时间与配合。</text>

    <view class="reward-card">
      <text class="card-label">您共获得</text>
      <text class="coins-total">{{coinsTotal}} 金币</text>
      <text class="yuan-equiv">可兑换 ¥{{rewardYuan}}</text>
    </view>

    <!-- payState: idle — primary claim button -->
    <view wx:if="{{payState === 'idle'}}" class="pay-section">
      <text class="pay-instructions">点击下方按钮即可领取您的红包奖励，红包将发放至您的微信钱包。</text>
      <button class="pay-btn" bindtap="onClaim">领取奖励 ¥{{rewardYuan}}</button>
    </view>

    <!-- payState: paying — disabled with spinner -->
    <view wx:elif="{{payState === 'paying'}}" class="pay-section">
      <text class="pay-instructions">正在发放红包，请稍候...</text>
      <button class="pay-btn" disabled loading="true">处理中</button>
    </view>

    <!-- payState: paid — success -->
    <view wx:elif="{{payState === 'paid'}}" class="pay-section pay-success">
      <text class="pay-success-icon">✅</text>
      <text class="pay-success-title">红包已发放</text>
      <text class="pay-success-body">¥{{rewardYuan}} 已发放至您的微信钱包，请稍后查收。</text>
      <text wx:if="{{transactionId}}" class="pay-success-txn">订单号：{{transactionId}}</text>
      <text class="pay-home-hint">您已完成本次研究，点击下方按钮返回主页继续使用。</text>
      <button class="pay-btn pay-btn-home" bindtap="onGoHome">返回主页</button>
    </view>

    <!-- payState: error — retryable -->
    <view wx:elif="{{payState === 'error'}}" class="pay-section pay-error">
      <text class="pay-error-icon">⚠️</text>
      <text class="pay-error-title">发放失败</text>
      <text class="pay-error-body">{{errorMsg}}</text>
      <button class="pay-btn pay-btn-retry" bindtap="onClaim">重试</button>
      <text class="pay-home-hint">本次研究已记录。如需协助处理奖励发放，请前往「个人积分」页面通过「联系我们」给我们留言。</text>
      <button class="pay-btn pay-btn-home" bindtap="onGoHome">返回主页</button>
    </view>

    <view class="confirmation-card">
      <text class="confirmation-label">您的确认编号</text>
      <text class="confirmation-id">{{confirmationId}}</text>
    </view>

  </view>

</view>
