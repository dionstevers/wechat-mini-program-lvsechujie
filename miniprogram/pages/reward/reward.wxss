.reward-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #00022a 0%, #009797 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.reward-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.reward-icon {
  font-size: 100rpx;
  margin-bottom: 8rpx;
}

.reward-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #f9bc60;
  text-align: center;
}

.reward-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
  line-height: 1.7;
}

.reward-card {
  width: 100%;
  background: rgba(249, 188, 96, 0.15);
  border: 2rpx solid rgba(249, 188, 96, 0.4);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.card-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
}

.coins-total {
  font-size: 60rpx;
  font-weight: bold;
  color: #f9bc60;
}

.yuan-equiv {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.instructions-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.instructions-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f9bc60;
}

.instructions-body {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.7;
}

.confirmation-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.confirmation-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

.confirmation-id {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 6rpx;
  font-family: monospace;
}
