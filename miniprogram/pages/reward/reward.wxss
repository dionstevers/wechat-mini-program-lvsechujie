.reward-page {
  min-height: 100vh;
  background: #419f8c;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.reward-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.reward-icon {
  font-size: 100rpx;
  margin-bottom: 8rpx;
}

.reward-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #f9bc60;
  text-align: center;
}

.reward-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  text-align: center;
  line-height: 1.7;
}

.reward-card {
  width: 100%;
  background: rgba(249, 188, 96, 0.15);
  border: 2rpx solid rgba(249, 188, 96, 0.4);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.card-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.65);
}

.coins-total {
  font-size: 60rpx;
  font-weight: bold;
  color: #f9bc60;
}

.yuan-equiv {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.instructions-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.instructions-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f9bc60;
}

.instructions-body {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.7;
}

.confirmation-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.confirmation-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
}

.confirmation-id {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 6rpx;
  font-family: monospace;
}

/* ── Pay state blocks ──────────────────────────────────────────────────── */
.pay-section {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.pay-instructions {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  text-align: center;
}

.pay-btn-wrap {
  width: 100%;
}

.pay-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  border: none;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #ffd27a 0%, #f9bc60 60%, #e5a23a 100%);
  color: #2a1a00;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(249, 188, 96, 0.45), inset 0 -2rpx 0 rgba(0, 0, 0, 0.08);
}
.pay-btn::after { border: none; }

.pay-btn[disabled] {
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.55);
  box-shadow: none;
}

.pay-btn-retry {
  background: #fff;
  color: #c95a4a;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.18);
}

.pay-btn-home {
  background: rgba(255, 255, 255, 0.92);
  color: #1f5b50;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.15);
  margin-top: 8rpx;
}

.pay-home-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  margin-top: 12rpx;
}

/* paid */
.pay-success {
  background: rgba(95, 168, 151, 0.18);
  border: 2rpx solid rgba(95, 168, 151, 0.55);
}

.pay-success-icon {
  font-size: 72rpx;
  line-height: 1;
}

.pay-success-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #d8f7ec;
}

.pay-success-body {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.6;
}

.pay-success-txn {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  font-family: monospace;
  letter-spacing: 1rpx;
}

/* error */
.pay-error {
  background: rgba(201, 90, 74, 0.18);
  border: 2rpx solid rgba(201, 90, 74, 0.6);
}

.pay-error-icon {
  font-size: 64rpx;
  line-height: 1;
}

.pay-error-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff0ec;
}

.pay-error-body {
  font-size: 24rpx;
  color: rgba(255, 224, 218, 0.92);
  text-align: center;
  line-height: 1.6;
}
