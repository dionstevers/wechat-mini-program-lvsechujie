<!--pages/trace/trace.wxml-->
<view class="container">
  <view class="section">
  <view class="section__title">
  请选择您的交通方式:
  </view>
  <picker bindchange="bindPickerChange" value="{{index}}" range="{{array}}">
    <view class="picker">
      {{array[index]}}
    </view>
  </picker>
</view>
  <view>
    <button class="btn1" bindtap="startTrack" disabled="{{isTracking}}">开始记录行程</button>
    <button class="btn2" bindtap="endTrack" disabled="{{!isTracking}}">结束记录行程</button>
  </view>
</view>