<!--pages/information/information.wxml-->
<block wx:if="{{isFromShareTimeline}}">
  <view class="page-background">
    <image class="QRcode" src="https://696c-iluvcarb-0gzvs45g82b57f98-1315168954.tcb.qcloud.la/logo/WechatIMG371.jpg?sign=1618ba30f1437e607318b76aa7335ad7&t=1720952079"></image>
  </view>
</block>

<block wx:else>
  <view class="page-background" style="background: {{background}};">
    <view class="page-introduction" style="font-family: 'Times New Roman', Times, serif;">
      为您提供最新的环境资讯和政策信息
    </view>

    <view>
      <view wx:for="{{articleShowList}}" wx:for-index="i" wx:key="i" class="container {{item.isUnread ? 'unread-highlight' : ''}}">
        <view bindtap="bindInfo" data-link="{{item.link}}">
          <view class="image-con">
            <image src="{{item.imgSrc}}" alt="des" mode="scaleToFill" class="img" />
          </view>
          <text class="info-con">{{item.date}} | {{item.author}}</text>

          <view class="preview-con">
            <view class="title">{{item.title}}</view>
            <view class="dislike" wx:if="{{item.author !== articleAuthors[-1] && !item.isUnread && userInfo}}">
              <image class="dislike-img" src="{{item.doDislike ? '../../asset/img/dislike-highlight.png' : '../../asset/img/dislike.png'}}" catchtap="bindDislike" data-link="{{item.link}}"></image>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</block>
