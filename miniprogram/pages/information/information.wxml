<!--pages/information/information.wxml-->
<view class="page-background">
  <view class="page-introduction">
    为您提供最新的环境资讯和政策信息
  </view>

  <view>
    <view wx:for="{{arlist}}" wx:for-index="i" wx:key="i" class="container">
    <view bindtap="bindInfo" data-title="{{item.link}}">
      <view class="image-con">
        <image src="{{item.imgUrl}}" alt="des" mode="widthFix" class="img" />
      </view>

      <text class="info-con">{{item._date}} | {{item.source}}</text>

      <view class="preview-con">
        <view class="title">{{item.title}}</view>
        <view class="ab">{{item.content}}</view>
      </view>
    </view>
    </view>
  </view>
</view>